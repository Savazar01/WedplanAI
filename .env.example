# ──────────────────────────────────────────────────────────────────────────────
# WedPlanAI — Environment Variables
# Copy this file to .env.local for local dev, or set these in Coolify's
# "Environment Variables" section for production.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose (internal network — web service connects to db service)
DATABASE_URL="postgresql://postgres:CHANGE_ME_DB_PASSWORD@db:5432/wedding_planner"

# ── Better Auth ───────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
BETTER_AUTH_SECRET="CHANGE_ME_MIN_32_CHAR_RANDOM_SECRET"

# Set to your public domain (must include https:// in production)
BETTER_AUTH_URL="https://your-domain.com"

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV="production"

# ── Docker Compose DB Credentials (used by the db service) ───────────────────
# These should match the DATABASE_URL above
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="CHANGE_ME_DB_PASSWORD"
POSTGRES_DB="wedding_planner"
